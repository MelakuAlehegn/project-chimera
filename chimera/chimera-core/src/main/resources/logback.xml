<?xml version="1.0" encoding="UTF-8"?>
<!--
  Logback config for Project Chimera.

  - Console output with timestamp, level, abbreviated logger, message.
  - Default level INFO; debug/trace can be enabled per-logger.
  - Quiet down noisy libraries (HikariCP, Postgres JDBC) to WARN.
-->
<configuration>

    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level [%logger{30}] %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Our code -->
    <logger name="com.chimera" level="INFO"/>

    <!-- Third-party noise reduction -->
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="org.postgresql" level="WARN"/>

    <!-- Catch-all -->
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>

</configuration>
