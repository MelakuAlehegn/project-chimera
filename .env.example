# Project Chimera environment variables.
# Copy this file to .env and fill in real values. Never commit .env.

# --- LLM ---
# Get a free key at https://aistudio.google.com/apikey (no credit card required)
GEMINI_API_KEY=AIza-your-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- PostgreSQL ---
# Local Postgres connection (peer auth on Linux uses no password).
DATABASE_URL=jdbc:postgresql://localhost:5432/chimera_dev
DATABASE_USER=dbuser
DATABASE_PASSWORD=dbpassword

# --- Bluesky ---
# Sign up at https://bsky.app and generate an app password under Settings.
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
CHIMERA_LOOP_INTERVAL_MINUTES=1

# --- MCP (optional) ---
# When true, the Manager saves drafts to disk via the filesystem MCP server.
# Requires Node + npx on PATH (the server is fetched via npx the first time).
CHIMERA_MCP_DRAFTS=false
CHIMERA_DRAFTS_DIR=/tmp/chimera-drafts
