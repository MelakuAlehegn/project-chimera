# Project Chimera environment variables.
# Copy this file to .env and fill in real values. Never commit .env.

# --- LLM ---
# Get a free key at https://aistudio.google.com/apikey (no credit card required)
GEMINI_API_KEY=AIza-your-key-here
GEMINI_MODEL=gemini-2.0-flash

# --- PostgreSQL ---
# Local Postgres connection (peer auth on Linux uses no password).
DATABASE_URL=jdbc:postgresql://localhost:5432/chimera_dev
DATABASE_USER=dbuser
DATABASE_PASSWORD=dbpassword
